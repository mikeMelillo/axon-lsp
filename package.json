{
  "name": "axon-lsp",
  "displayName": "Axon Language Support",
  "description": "LSP and Syntax Highlighting for the Axon programming language",
  "version": "0.1.0",
  "publisher": "mike",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "axon",
        "aliases": ["Axon", "axon"],
        "extensions": [".axon", ".trio"],
        "configuration": "./language-configuration.json"
      }
    ]
  },
  "activationEvents": [
    "onLanguage:axon"
  ],
  "main": "./client/out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./client",
    "watch": "tsc -watch -p ./client",
    "postinstall": "npm install --prefix client"
  },
  "devDependencies": {
    "@types/node": "^16.11.7",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.1.6"
  }
}