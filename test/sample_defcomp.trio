name:spark_damperOpen
func
ruleOn:equip and vav
sparkRule
src:
  // Potential comments
  defcomp
    target: {}
    date:   {}
    out:    {readonly}
    damp:   {bind:"point and his and cmd and damper and equipRef->vav and equipRef=={{target->id}}"}
    occSched: {bindTuning:"occSchRef"}
    do
    
    occHis  :  try (occSched).hisRead(date).hisFindPeriods(x => x==true)
               catch null     
    
    dampHis  : damp.hisRead(date, {limit:null}).hisClip
    dampOpen : dampHis.hisFindPeriods(x => x != na() and x>80) 
    spkPds   : dampOpen.hisFindAll(v => v>=2hr)
    spk      : if(occHis != null) hisPeriodIntersection([occHis,spkPds])
               else spkPds
       
    if (spk==null or spk.isEmpty) return null else spk
    out = spk
       
    end
  end
