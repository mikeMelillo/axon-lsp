{
  "name": "axon-lsp",
  "displayName": "Axon LSP (Project Haystack)",
  "description": "LSP and Syntax Highlighting for the Axon programming language",
  "version": "0.1.7",
  "publisher": "mikeMelillo",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "axon",
        "aliases": ["Axon", "axon"],
        "extensions": [".axon", ".trio"],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "Axon LSP",
      "properties": {
        "axonLsp.haxallPaths": {
          "type": "array",
          "default": [],
          "description": "Paths to Haxall installation directories (clone from https://github.com/haxall/haxall/tree/3.1.12)"
        },
        "axonLsp.externalPaths": {
          "type": "array",
          "default": [],
          "description": "Additional paths to scan for Axon functions (for supporting your local codebase outside of current working directory)"
        }
      }
    },
    "commands": [
        {
            "command": "extension.openExternal",
            "title": "Open External URL"
        }
    ]
  },
  "main": "./client/out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./client",
    "watch": "tsc -watch -p ./client",
    "postinstall": "npm install --prefix client",
    "package": "vsce package -o build",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^16.11.7",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.1.6"
  },
  "repository": "https://github.com/mikeMelillo/axon-lsp"
}